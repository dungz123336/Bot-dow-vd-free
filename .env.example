# Token từ @BotFather (bắt buộc) — dạng: 123456789:AAHxxxx...
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram User ID của Admin (số)
ADMIN_ID=5949258698

# Cổng web dashboard
WEB_PORT=8080
WEB_HOST=0.0.0.0

# Chỉ cho phép Admin dùng bot? true/false
ADMIN_ONLY=false

# Thời lượng cắt mặc định (giây) nếu user không chọn
DEFAULT_SPLIT_SECONDS=30

# Giới hạn kích thước file gửi Telegram (MB) — Bot API ~50MB
MAX_TELEGRAM_MB=49
